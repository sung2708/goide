{
  "name": "goide",
  "private": true,
  "version": "0.1.0",
  "description": "A desktop IDE for Go editing, runtime inspection, and concurrency workflows.",
  "license": "MIT",
  "homepage": "https://github.com/sung2708/goide",
  "repository": {
    "type": "git",
    "url": "https://github.com/sung2708/goide.git"
  },
  "keywords": ["go", "ide", "tauri", "react", "debugger"],
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev:msvc": "set CC=cl&& set CXX=cl&& npm run tauri -- dev",
    "test": "vitest run"
  },
  "dependencies": {
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-regular-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.0",
    "@lezer/highlight": "^1.2.3",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@uiw/react-codemirror": "^4.25.9",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4.1.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.1.3"
  }
}
